{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid"]
    },
    "Route": {
      "title": "Saved Route",
      "description": "A route saved by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "startPoint": { "type": "object" },
        "endPoint": { "type": "object" },
        "waypoints": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPublic": { "type": "boolean" }
      },
      "required": ["ownerId", "name", "startPoint", "endPoint"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "routes/{routeId}": {
      "schema": "Route",
      "description": "Shared and saved routes"
    }
  }
}
